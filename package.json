{
  "name": "native-launcher",
  "productName": "Native",
  "desktopName": "Native.desktop",
  "version": "3.4.6",
  "description": "Native — a fast, beautiful Minecraft launcher",
  "main": "./out/main/index.js",
  "author": {
    "name": "Native Labs",
    "email": "support@nativelauncher.app"
  },
  "homepage": "https://github.com/ikie-cli/native",
  "repository": {
    "type": "git",
    "url": "https://github.com/ikie-cli/native.git"
  },
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:ranked": "node scripts/build-ranked.mjs",
    "deploy:ranked-mod": "node scripts/deploy-ranked-mod.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run",
    "test:ranked": "npm --prefix ranked-server test",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "e2e": "playwright test --project e2e",
    "qa:visual": "playwright test --project visual-qa && node scripts/qa-report.mjs",
    "package:linux": "npm run build:ranked && electron-vite build && electron-builder --linux",
    "package:win": "npm run build:ranked && electron-vite build && electron-builder --win",
    "package:mac": "npm run build:ranked && electron-vite build && electron-builder --mac",
    "package:dir": "npm run build:ranked && electron-vite build && electron-builder --dir",
    "postinstall": "node scripts/patch-nsis.mjs || true",
    "package:win-host": "npm run build:ranked && electron-vite build && NSIS_UNINSTALLER_READER=true electron-builder --win nsis --x64 -c.win.signAndEditExecutable=false -c.nsis.warningsAsErrors=false",
    "brand:win": "node scripts/brand-win-exe.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@xhayper/discord-rpc": "^1.3.4",
    "better-sqlite3": "^12.6.2",
    "dompurify": "^3.4.12",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "marked": "^18.0.7",
    "msmc": "^5.0.5",
    "skinview3d": "^3.4.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@playwright/test": "^1.49.1",
    "@tanstack/react-virtual": "^3.11.2",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "adm-zip": "^0.6.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "framer-motion": "^11.15.0",
    "happy-dom": "^20.11.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.469.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resedit": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10",
    "zustand": "^5.0.2"
  }
}
